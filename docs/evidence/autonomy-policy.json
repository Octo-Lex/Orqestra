{
  "schema_version": 1,
  "description": "Current autonomy policy status. Sourced from v2.6.0–v2.9.0 release records.",
  "provenance": "Autonomy policy evidence derived from security/auto_apply.rs constants and release records.",
  "status": "docs-only pilot",
  "allowed_paths": ["docs/**", "README.md"],
  "excluded_paths": ["CHANGELOG.md", "roadmap/**"],
  "confidence_threshold_docs": 0.80,
  "confidence_threshold_readme": 0.90,
  "threshold_note": "README.md uses stricter threshold (0.90) than docs/ (0.80).",
  "max_session_cap": 10,
  "default_cap": 5,
  "min_cap": 1,
  "auto_commit": false,
  "audit_schema_version": 1,
  "rejection_reasons": 17,
  "rejection_reason_list": [
    "AutonomyDisabled",
    "WrongAgent",
    "WrongOperation",
    "AutoCommitNotFalse",
    "PathForbidden",
    "PathNotInAllowlist",
    "PathExcluded",
    "OperationalRiskBlocked",
    "CredentialSecretRisk",
    "WorkflowRisk",
    "DependencyRisk",
    "PatchTooLarge",
    "ConfidenceBelowThreshold",
    "BeforeChecksumMismatch",
    "SessionCapExceeded",
    "TraversalAttempt",
    "BinaryFile"
  ],
  "allowed_agents": ["docs"],
  "disallowed_operations": ["source-code auto-apply", "bugfix-agent autonomy", "architect writes", "auto_commit"]
}
